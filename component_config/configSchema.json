{
  "type": "object",
  "title": "Tiketo Pass Manager Configuration",
  "required": ["#token", "action"],
  "properties": {
    "#token": {
      "type": "string",
      "title": "API Token",
      "description": "Your Tiketo CMS API token",
      "format": "password",
      "propertyOrder": 1
    },
    "action": {
      "type": "string",
      "title": "Action",
      "description": "Extract pulls all data from Tiketo. Write performs a specific operation on a chosen entity.",
      "enum": ["extract", "write"],
      "default": "extract",
      "propertyOrder": 2
    },
    "entity": {
      "type": "string",
      "title": "Entity",
      "description": "Select the entity type to work with",
      "enum": ["passes", "members", "venues", "organizations", "campaigns"],
      "propertyOrder": 3,
      "options": {
        "dependencies": {
          "action": "write"
        }
      }
    },
    "operation": {
      "type": "string",
      "title": "Operation",
      "description": "Select the operation to perform on the chosen entity",
      "propertyOrder": 4,
      "options": {
        "dependencies": {
          "action": "write"
        }
      }
    },
    "batch_size": {
      "type": "integer",
      "title": "Batch Size",
      "description": "Number of items to process per API request (1-100)",
      "default": 50,
      "minimum": 1,
      "maximum": 100,
      "propertyOrder": 5,
      "options": {
        "dependencies": {
          "action": "write"
        }
      }
    },
    "message_header": {
      "type": "string",
      "title": "Notification Header",
      "description": "Push notification header text",
      "propertyOrder": 10,
      "options": {
        "dependencies": {
          "action": "write",
          "entity": "campaigns"
        }
      }
    },
    "message_body": {
      "type": "string",
      "title": "Notification Body",
      "description": "Push notification body text (required for campaign creation)",
      "propertyOrder": 11,
      "options": {
        "dependencies": {
          "action": "write",
          "entity": "campaigns"
        }
      }
    },
    "template_ids": {
      "type": "array",
      "title": "Template IDs",
      "description": "Template IDs to target with template campaign",
      "items": {
        "type": "string"
      },
      "propertyOrder": 12,
      "options": {
        "dependencies": {
          "action": "write",
          "entity": "campaigns"
        }
      }
    },
    "date_from": {
      "type": "string",
      "title": "Campaign Start Date",
      "description": "Campaign start date (ISO format, optional)",
      "propertyOrder": 13,
      "options": {
        "dependencies": {
          "action": "write",
          "entity": "campaigns"
        }
      }
    },
    "date_to": {
      "type": "string",
      "title": "Campaign End Date",
      "description": "Campaign end date (ISO format, optional)",
      "propertyOrder": 14,
      "options": {
        "dependencies": {
          "action": "write",
          "entity": "campaigns"
        }
      }
    }
  }
}
